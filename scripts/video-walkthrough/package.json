{
  "name": "senopati-walkthrough-recorder",
  "private": true,
  "version": "1.0.0",
  "description": "Playwright recorder for the tutor walkthrough video (STORYBOARD.md rev-2).",
  "scripts": {
    "record": "tsx record.ts",
    "record:headless": "RECORD_HEADLESS=1 tsx record.ts",
