# ─── Copy ke .env.local untuk development, atau .env.production.local untuk prod.
# Semua nilai di bawah ini adalah CONTOH — ganti dengan milikmu sendiri.

# ─── CMS & Media (external services, optional) ───────────────────────────────
NEXT_PUBLIC_CMS_URL=https://cms.asksenopati.com
NEXT_PUBLIC_MEDIA_URL=https://news.asksenopati.com

# ─── Database ────────────────────────────────────────────────────────────────
# Dev default: docker-compose yang ada di repo ini (port 5434).
# Production: ganti host/credentials dengan managed Postgres (Supabase, RDS, dll).
DATABASE_URL=postgresql://senopati:senopati@127.0.0.1:5434/senopati_academy?schema=public

# Optional — digunakan docker-compose.yml kalau ingin override dari default.
POSTGRES_USER=senopati
POSTGRES_PASSWORD=senopati
POSTGRES_DB=senopati_academy
POSTGRES_HOST_PORT=5434

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate production secret: openssl rand -base64 32
NEXTAUTH_SECRET=dev-only-replace-me-with-random-string
NEXTAUTH_URL=http://localhost:3003

# Google OAuth (opsional) — isi setelah setup di Google Cloud Console.
# Authorized redirect URI: ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Object Storage (S3 / MinIO) ─────────────────────────────────────────────
# Dev default: docker-compose MinIO (port 9002).
S3_ENDPOINT=http://127.0.0.1:9002
S3_PUBLIC_URL=http://127.0.0.1:9002/senopati-academy
S3_REGION=us-east-1
S3_BUCKET=senopati-academy
S3_ACCESS_KEY=senopati
S3_SECRET_KEY=senopati-storage-secret
S3_FORCE_PATH_STYLE=true

MINIO_ROOT_USER=senopati
MINIO_ROOT_PASSWORD=senopati-storage-secret
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9003

# Public URL yang dipakai Next.js Image untuk asset upload
NEXT_PUBLIC_ACADEMY_MEDIA_URL=http://127.0.0.1:9002/senopati-academy

# ─── Site ────────────────────────────────────────────────────────────────────
# Dipakai di sertifikat / verify URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3003
